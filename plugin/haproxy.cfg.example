# Prefer Easy_setup_HAProxy instead of editing HAProxy manually.
# This is a snippet, not a replacement for /etc/haproxy/haproxy.cfg.
# Back up the complete file and validate it with `haproxy -c -f` first.

# Add inside the frontend or listen section bound to TCP port 80:
        acl alexaoctoprint_description path -i /description.xml
        acl alexaoctoprint_api_root path -i /api
        acl alexaoctoprint_api_user path_reg -i ^/api/[0-9a-fA-F]{40}/?$
        acl alexaoctoprint_lights path_reg -i ^/api/[0-9a-fA-F]{40}/lights(/[0-9]+(/state)?)?/?$
        acl alexaoctoprint_get method GET
        acl alexaoctoprint_post method POST
        acl alexaoctoprint_state_write method PUT POST
        use_backend alexaoctoprint_hue if alexaoctoprint_description alexaoctoprint_get
        use_backend alexaoctoprint_hue if alexaoctoprint_api_root alexaoctoprint_post
        use_backend alexaoctoprint_hue if alexaoctoprint_api_user alexaoctoprint_get
        use_backend alexaoctoprint_hue if alexaoctoprint_lights alexaoctoprint_get
        use_backend alexaoctoprint_hue if alexaoctoprint_lights alexaoctoprint_state_write

# Add at the end of the file. Change port 5000 only when OctoPrint uses another
# internal port.
backend alexaoctoprint_hue
        http-request set-header X-AlexaOctoPrint-Original-Path %[path]
        http-request set-path /plugin/alexaoctoprint%[path]
        option forwardfor
        server alexaoctoprint 127.0.0.1:5000
