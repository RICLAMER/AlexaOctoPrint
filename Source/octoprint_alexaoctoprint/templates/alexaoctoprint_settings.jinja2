<form class="form-horizontal">
  <div class="alexaoctoprint-settings">
    <h3>Alexa OctoPrint</h3>

    <div class="control-group">
      <label class="control-label">{{ _('Enabled') }}</label>
      <div class="controls">
        <label class="checkbox">
          <input type="checkbox" data-bind="checked: settings.settings.plugins.alexaoctoprint.enabled">
          {{ _('Enable local Alexa bridge') }}
        </label>
      </div>
    </div>

    <div class="control-group">
      <label class="control-label">{{ _('Language') }}</label>
      <div class="controls">
        <select data-bind="value: settings.settings.plugins.alexaoctoprint.language">
          <option value="pt">Português</option>
          <option value="en">English</option>
          <option value="es">Español</option>
        </select>
      </div>
    </div>

    <div class="control-group">
      <label class="control-label">{{ _('Debug') }}</label>
      <div class="controls alexaoctoprint-inline-controls">
        <label class="checkbox inline">
          <input type="checkbox" data-bind="checked: settings.settings.plugins.alexaoctoprint.debug.enabled">
          {{ _('Enabled') }}
        </label>
        <input type="number" class="input-small" min="10" data-bind="value: settings.settings.plugins.alexaoctoprint.debug.max_events">
        <button type="button" class="btn" data-bind="click: refreshDebug">
          <i class="fa fa-refresh"></i> {{ _('Refresh') }}
        </button>
      </div>
    </div>

    <div class="alexaoctoprint-debug" data-bind="with: debugStatus">
      <div><strong>{{ _('Description') }}:</strong> <span data-bind="text: location"></span></div>
      <div><strong>{{ _('SSDP') }}:</strong> <span data-bind="text: ssdp.running ? 'running' : 'stopped'"></span></div>
      <div><strong>{{ _('Searches') }}:</strong> <span data-bind="text: ssdp.search_requests || 0"></span></div>
      <div><strong>{{ _('Last Echo') }}:</strong> <span data-bind="text: ssdp.last_search_from || '-'"></span></div>
      <div data-bind="with: hue_http">
        <strong>{{ _('Hue HTTP') }}:</strong>
        <span data-bind="text: total || 0"></span>
        <span data-bind="text: last_stage || '-'"></span>
        <span data-bind="text: last_remote || '-'"></span>
      </div>
    </div>

    <div class="alert alert-warning" data-bind="visible: enclosureStatus() && !enclosureStatus().available">
      <strong>{{ _('Enclosure') }}:</strong>
      <span data-bind="text: enclosureStatus() ? enclosureStatus().error : ''"></span>
    </div>

    <div class="alexaoctoprint-proxy">
      <h4>{{ _('Port 80 routing') }}</h4>
      <div class="alexaoctoprint-inline-controls">
        <button type="button" class="btn" data-bind="click: inspectProxy">
          <i class="fa fa-search"></i> {{ _('Inspect') }}
        </button>
        <button type="button" class="btn btn-primary" data-bind="click: installProxy">
          <i class="fa fa-wrench"></i> {{ _('Install / update routes') }}
        </button>
        <button type="button" class="btn btn-danger" data-bind="click: removeProxy">
          <i class="fa fa-undo"></i> {{ _('Restore previous configuration') }}
        </button>
      </div>
      <pre data-bind="visible: proxyStatus, text: proxyStatusText"></pre>
    </div>

    <div class="alexaoctoprint-actions-toolbar">
      <button type="button" class="btn" data-bind="click: refreshFiles">
        <i class="fa fa-refresh"></i> {{ _('Refresh files') }}
      </button>
    </div>

    <table class="table table-condensed table-striped alexaoctoprint-actions">
      <thead>
        <tr>
          <th>{{ _('Action') }}</th>
          <th>{{ _('Custom name') }}</th>
          <th>{{ _('Parameters') }}</th>
          <th>{{ _('Test') }}</th>
        </tr>
      </thead>
      <tbody data-bind="foreach: actionList">
        <tr>
          <td>
            <label class="checkbox">
              <input type="checkbox" data-bind="checked: $root.actionSetting($data, 'enabled')">
              <span data-bind="text: name"></span>
            </label>
            <code data-bind="text: key"></code>
          </td>
          <td>
            <input type="text" class="input-large" data-bind="value: $root.actionSetting($data, 'name')" placeholder="Alexa device name">
            <label class="checkbox">
              <input type="checkbox" data-bind="checked: $root.actionSetting($data, 'allow_while_printing')">
              {{ _('Allow while printing') }}
            </label>
          </td>
          <td>
            <div data-bind="visible: $root.hasSetting($data, 'temperature')">
              <label>{{ _('Temperature') }}</label>
              <input type="number" class="input-small" data-bind="value: $root.actionSetting($data, 'temperature')">
            </div>
            <div data-bind="visible: $root.hasSetting($data, 'extrusion_mm')">
              <label>{{ _('Extrusion mm') }}</label>
              <input type="number" step="0.1" class="input-small" data-bind="value: $root.actionSetting($data, 'extrusion_mm')">
            </div>
            <div data-bind="visible: $root.hasSetting($data, 'distance_mm')">
              <label>{{ _('Distance mm') }}</label>
              <input type="number" step="0.1" class="input-small" data-bind="value: $root.actionSetting($data, 'distance_mm')">
            </div>
            <div data-bind="visible: $root.hasSetting($data, 'feedrate')">
              <label>{{ _('Feedrate') }}</label>
              <input type="number" class="input-small" data-bind="value: $root.actionSetting($data, 'feedrate')">
            </div>
            <div data-bind="visible: $root.hasSetting($data, 'gcode')">
              <label data-bind="text: supports_off ? '{{ _('On G-code') }}' : '{{ _('G-code') }}'"></label>
              <textarea rows="3" class="input-xlarge" data-bind="value: $root.actionSetting($data, 'gcode')"></textarea>
            </div>
            <div data-bind="visible: $root.hasSetting($data, 'off_gcode')">
              <label>{{ _('Off G-code') }}</label>
              <textarea rows="3" class="input-xlarge" data-bind="value: $root.actionSetting($data, 'off_gcode')"></textarea>
            </div>
            <div data-bind="visible: $root.hasSetting($data, 'file_path')">
              <label>{{ _('File') }}</label>
              <select class="input-xlarge" data-bind="options: $root.files, optionsText: 'label', optionsValue: 'path', value: $root.actionSetting($data, 'file_path')"></select>
              <input type="text" class="input-small" data-bind="value: $root.actionSetting($data, 'file_origin')">
            </div>
            <div data-bind="visible: $root.hasSetting($data, 'enclosure_label')">
              <label>{{ _('Enclosure label') }}</label>
              <select class="input-large"
                      data-bind="options: $root.enclosureLabels,
                                 optionsText: 'label',
                                 optionsValue: 'label',
                                 optionsCaption: '{{ _('Select a Label') }}',
                                 value: $root.actionSetting($data, 'enclosure_label'),
                                 valueAllowUnset: true,
                                 enable: $root.enclosureAvailable"></select>
            </div>
          </td>
          <td>
            <button type="button" class="btn btn-small" data-bind="click: $root.runActionOn">
              <i class="fa fa-play"></i> <span data-bind="text: supports_off ? '{{ _('On') }}' : '{{ _('Run') }}'"></span>
            </button>
            <button type="button" class="btn btn-small" data-bind="visible: supports_off, click: $root.runActionOff">
              <i class="fa fa-stop"></i> {{ _('Off') }}
            </button>
          </td>
        </tr>
      </tbody>
    </table>

    <div class="alexaoctoprint-events" data-bind="with: debugStatus">
      <h4>{{ _('Recent events') }}</h4>
      <table class="table table-condensed">
        <tbody data-bind="foreach: events">
          <tr>
            <td data-bind="text: time"></td>
            <td data-bind="text: type"></td>
            <td data-bind="text: message"></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</form>
